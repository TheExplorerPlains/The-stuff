-- Orbit Around Their Plate (96×1×96), matching linear speed
orbitClick.MouseButton1Click:Connect(function()
    if not currentSel then return end

    local selModel = currentSel
    local name     = selModel.Name
    local ctrl     = controllers[name]
    if not ctrl then return end

    if ctrl.conn then
        ctrl.conn:Disconnect()
        ctrl.conn = nil
        ctrl.running = false
        stopLabel.Text  = "Resume Plate"
        bringLabel.Text = "Bring To Me"
    end

    if ctrl.playerConn then
        ctrl.playerConn:Disconnect()
        ctrl.playerConn = nil
        startOrbit(name)
        orbitLabel.Text = "Orbit Around Their Plate"
        return
    end

    local input = orbitBox.Text:lower()
    local target
    for _, p in ipairs(Players:GetPlayers()) do
        if p.Name:lower():find(input, 1, true)
        or p.DisplayName:lower():find(input, 1, true) then
            target = p
            break
        end
    end
    if not target then
        warn("No matching player for input:", orbitBox.Text)
        return
    end

    local platesFolder = Workspace:FindFirstChild("Plates")
    local theirPF
    if platesFolder then
        for _, v in ipairs(platesFolder:GetChildren()) do
            if v:FindFirstChild("Owner") and v.Owner.Value == target then
                theirPF = v
                break
            end
        end
    end
    if not (theirPF and theirPF:FindFirstChild("Plate")) then
        warn("Could not find target player's Plate")
        return
    end

    local centerPlate  = theirPF.Plate
    local centerCFrame = centerPlate.CFrame

    local ang = 0
    local yOffset = (plateSize.Y/2) + heightOffset

    local startCF   = selModel.PrimaryPart.CFrame
    local oriOffset = startCF - startCF.Position

    local playerAngularSpeed = orbitSpeed * (orbitRadius / playerOrbitRadius)

    ctrl.playerConn = RunService.Heartbeat:Connect(function(dt)
        ang += playerAngularSpeed * dt
        local pos = centerCFrame.Position
        local x = pos.X + playerOrbitRadius * math.cos(ang)
        local z = pos.Z + playerOrbitRadius * math.sin(ang)
        local newC0 = CFrame.new(x, pos.Y + yOffset, z)
        selModel:SetPrimaryPartCFrame(newC0 * oriOffset)
    end)

    orbitLabel.Text = "Return to Map Orbit"
end)

