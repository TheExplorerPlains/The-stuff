local StampAsset = Replicated:WaitForChild("Remotes"):WaitForChild("StampAsset")
local mapSize, trackOffset       = Vector3.new(538,1,538), 30
local orbitSpeedDeg, spacing, coreSize, coreTrans = 3, 4, Vector3.new(4,4,4), 0.5
local heightOffset               = coreSize.Y/2 + 0.1
local plateSize                  = Vector3.new(96,1,96)
local spawnHeightAbovePlate      = 50
local settleThreshold, settleTimeout = 0.1, 5
local baseRadius  = math.sqrt((mapSize.X/2)^2 + (mapSize.Z/2)^2)
local orbitRadius = baseRadius + trackOffset
local mapCenter   = Vector3.new(0,0,0)

local plateBaseRadius   = math.sqrt((plateSize.X/2)^2 + (plateSize.Z/2)^2)
local playerOrbitRadius = plateBaseRadius + trackOffset
local orbitSpeed        = math.rad(orbitSpeedDeg)

local function waitForNewModel(act, before, timeout)
    timeout = timeout or 2
    for i = 1, timeout*60 do
        for _, c in ipairs(act:GetChildren()) do
            if not table.find(before, c) then return c end
        end
        RunService.Heartbeat:Wait()
    end
    error("Timed out")
end

local function spawnAsset(act, id, guid, cf)
    local before = act:GetChildren()
    pcall(function() StampAsset:InvokeServer(id, cf, guid, {}, 1) end)
    local mdl = waitForNewModel(act, before)
    return (mdl:IsA("BasePart") and mdl) or mdl:FindFirstChildWhichIsA("BasePart", true)
end

local function waitForAllSettle(pairs)
    local t0 = tick()
    while true do
        local done = true
        for _, p in ipairs(pairs) do
            if (p.stamped.Position - p.core.Position).Magnitude > settleThreshold then
                done = false
                break
            end
        end
        if done or tick() - t0 > settleTimeout then return end
        RunService.Heartbeat:Wait()
    end
end

-- Refresh and sort selection list (in SelectionPage)
local function refreshSelection()
    for _, c in ipairs(scroll:GetChildren()) do
        if c:IsA("Frame") then c:Destroy() end
    end
    local names = {}
    for name in pairs(plates) do
        table.insert(names, name)
    end
    table.sort(names, function(a,b)
        local na = tonumber(a:match("Plate(%d+)")) or 0
        local nb = tonumber(b:match("Plate(%d+)")) or 0
        return na < nb
    end)
    scroll.CanvasSize = UDim2.new(0, 0, 0, #names * 55 + 10)
    for idx, name in ipairs(names) do
        local model = plates[name]
        local btnFrame = Instance.new("Frame", scroll)
        btnFrame.Size             = UDim2.new(1, 0, 0, 50)
