-- Orbit around map‑center
local function startOrbit(name)
    local guide = plates[name]
    if not guide then return end
    local prim = assert(guide.PrimaryPart, "No PrimaryPart")
    local cf0, ang = prim.CFrame, 0
    controllers[name].conn = RunService.Heartbeat:Connect(function(dt)
        ang += orbitSpeed * dt
        local x = mapCenter.X + orbitRadius * math.cos(ang)
        local z = mapCenter.Z + orbitRadius * math.sin(ang)
        guide:SetPrimaryPartCFrame(
            CFrame.new(x, cf0.Y, z)
            * cf0:ToObjectSpace(CFrame.new(cf0.Position))
        )
    end)
    controllers[name].running = true
end

-- Build Plate
local isBuilding = false
local function buildPlate()
    if isBuilding then return end
    isBuilding = true
    createFrame.BackgroundColor3 = Color3.fromRGB(100,100,100)

    local pf = assert(Workspace:FindFirstChild("Plates"), "No Plates folder")
    local myPF
    for _, v in ipairs(pf:GetChildren()) do
        if v:FindFirstChild("Owner") and v.Owner.Value == player then
            myPF = v
            break
        end
    end
    assert(myPF, "Couldn’t find your Plate")
    local LPlate = myPF:FindFirstChild("Plate")
    local ActiveParts = myPF:FindFirstChild("ActiveParts")

    plateCount += 1
    local pname = "Plate"..plateCount
    local guide = Instance.new("Model", Workspace)
    guide.Name = pname

    local stamped, offsets = {}, {}
    for r = 1, rows do
        offsets[r] = (r - (rows+1)/2) * spacing
    end
    local baseCF = LPlate.CFrame * CFrame.new(-((cols-1)*spacing)/2, heightOffset, 0)

    for r, z in ipairs(offsets) do
        for c = 1, cols do
            local core = Instance.new("Part")
            core.Name, core.Size, core.Anchored, core.CanCollide, core.Transparency =
              ("Core_R%d_C%d"):format(r,c), coreSize, true, false, coreTrans
            core.CFrame = baseCF * CFrame.new((c-1)*spacing, 0, z)
            core.Parent = guide

            -- Determine which asset to use:
            local assetId, assetGUID
            if randomizeAssets then
                local choice = assetOptions[math.random(1, #assetOptions)]
                assetId   = choice.AssetId
                assetGUID = choice.GUID
            else
                assetId   = currentAssetId
                assetGUID = currentAssetGUID
            end

            local part = spawnAsset(ActiveParts, assetId, assetGUID,
                LPlate.CFrame * CFrame.new(0, spawnHeightAbovePlate, 0))
            part.Name, part.Anchored, part.CanCollide =
              ("Stamp_R%d_C%d"):format(r,c), false, false

            local a0 = Instance.new("Attachment", part)
            local a1 = Instance.new("Attachment", core)
            local ap = Instance.new("AlignPosition", part)
            ap.Attachment0,ap.Attachment1,ap.RigidityEnabled,ap.Responsiveness,ap.MaxForce =
              a0,a1,true,200,1e5
            local ao = Instance.new("AlignOrientation", part)
            ao.Attachment0,ao.Attachment1,ao.RigidityEnabled,ao.Responsiveness,ao.MaxTorque =
              a0,a1,true,200,1e5

            table.insert(stamped,{stamped=part,core=core})
        end
    end

    waitForAllSettle(stamped)

    local prim = assert(guide:FindFirstChildWhichIsA("BasePart"), "No BasePart")
    guide.PrimaryPart = prim

    plates[pname]      = guide
    controllers[pname] = { conn = nil, running = false, playerConn = nil }

    -- If routingActive, place the plate’s true grid–center at ROUTE_START_POS
    if routingActive then
        -- collect “Core_” parts
        local cores = {}
        for _, part in ipairs(guide:GetDescendants()) do
            if part:IsA("BasePart") and part.Name:match("^Core_R%d+_C%d+") then
                table.insert(cores, part)
            end
        end
        if #cores == 0 then
            -- fallback
            local pivotCFrame = guide.PrimaryPart.CFrame
            local offset = pivotCFrame:ToObjectSpace(guide.PrimaryPart.CFrame)
            guide:SetPrimaryPartCFrame(CFrame.new(ROUTE_START_POS + Vector3.new(0, heightOffset, 0)) * offset)
        else
            local sum = Vector3.new(0, 0, 0)
            for _, core in ipairs(cores) do
                sum = sum + core.Position
            end
            local center = sum / #cores
            local pivotCFrame = CFrame.new(center)
            local offset = pivotCFrame:ToObjectSpace(guide.PrimaryPart.CFrame)
            guide:SetPrimaryPartCFrame(CFrame.new(ROUTE_START_POS + Vector3.new(0, heightOffset, 0)) * offset)
        end
    else
        -- If no routing, just orbit normally
        startOrbit(pname)
    end

    refreshSelection()

    isBuilding = false
    createFrame.BackgroundColor3 = Color3.fromRGB(55, 55, 70)
end

