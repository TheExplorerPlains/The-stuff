-- ────────────────────────────────────────────────────────────
-- PULSING UTILITY (for routing cubes & guide parts)
-- ────────────────────────────────────────────────────────────
local isPulsing = {}
local pulseTweenInfo = TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)

local function pulse(part)
    if isPulsing[part] then return end
    isPulsing[part] = true

    local origT = part.Transparency
    local origC = part.Color
    -- flash to green
    local flash = origC:Lerp(Color3.new(0,1,0), 0.7)

    local t1 = TweenService:Create(part, pulseTweenInfo, {
        Transparency = 0,
        Color = flash,
    })
    local t2 = TweenService:Create(part, pulseTweenInfo, {
        Transparency = origT,
        Color = origC,
    })

    t1:Play()
    t1.Completed:Connect(function()
        t2:Play()
        t2.Completed:Connect(function()
            isPulsing[part] = nil
        end)
    end)
end

-- ────────────────────────────────────────────────────────────
-- ROUTING‑CUBE: spawn one layered cube (outer+inner) at cf
-- Outer’s Touched → pulse(hit part) if part belongs to any guide
-- ────────────────────────────────────────────────────────────
local function spawnRouteCube(cf, outerSize, innerSize, outerColor, outerTransp, innerColor, innerTransp, innerMat)
    -- Outer MeshPart (handles Touched → pulse)
    local outer = Instance.new("MeshPart")
    outer.MeshId       = ROUTE_MESH_ID
    outer.Size         = outerSize
    outer.CFrame       = cf
    outer.Anchored     = true
    outer.CanCollide   = false
    outer.CanTouch     = true
    outer.Material     = Enum.Material.Neon
    outer.Color        = outerColor
    outer.Transparency = outerTransp
    outer.Parent       = workspace
    table.insert(routeParts, outer)

    outer.Touched:Connect(function(hit)
        -- If this outer cube is touched by any part that belongs to a "guide" model,
        -- pulse that part.
        for _, guideModel in pairs(plates) do
            if hit:IsDescendantOf(guideModel) then
                pulse(hit)
                break
            end
        end
    end)

    -- Inner MeshPart (visual only)
    local inner = Instance.new("MeshPart")
    inner.MeshId       = ROUTE_MESH_ID
    inner.Size         = innerSize
    inner.CFrame       = cf
    inner.Anchored     = true
    inner.CanCollide   = false
    inner.CanTouch     = false
    inner.Material     = innerMat or Enum.Material.Neon
    inner.Color        = innerColor
    inner.Transparency = innerTransp
    inner.Parent       = workspace
    table.insert(routeParts, inner)
end

-- ────────────────────────────────────────────────────────────
-- SPAWN THE ENTIRE “ROUTE A” LINE
-- ────────────────────────────────────────────────────────────
local function spawnRouteA()
    if routingActive then return end

    local direction     = (ROUTE_END_POS - ROUTE_START_POS)
    local totalDistance = direction.Magnitude
    if totalDistance == 0 then return end
    local forward = direction.Unit

    -- Compute bar length = distance − 2 * OUTER_SIZE.Z
    local barLength = math.max(0, totalDistance - (ROUTE_OUTER_SIZE.Z * 2))

    -- 1) Start cap
    local startCF = CFrame.new(ROUTE_START_POS, ROUTE_START_POS + forward)
    spawnRouteCube(
        startCF,
        ROUTE_OUTER_SIZE, ROUTE_INNER_SIZE,
        ROUTE_OUTER_COLOR, ROUTE_OUTER_TRANSP,
        ROUTE_INNER_COLOR, ROUTE_INNER_TRANSP
    )

    -- 2) Bar (if length > 0)
    if barLength > 0 then
        local halfDist  = ROUTE_OUTER_SIZE.Z + (barLength / 2)
        local barCenter = ROUTE_START_POS + forward * halfDist

        local barPart = Instance.new("Part")
        barPart.Size         = Vector3.new(ROUTE_LINE_THICKNESS, ROUTE_LINE_THICKNESS, barLength)
        barPart.CFrame       = CFrame.new(barCenter, barCenter + forward)
        barPart.Anchored     = true
        barPart.CanCollide   = false
        barPart.Material     = Enum.Material.Neon
        barPart.Color        = ROUTE_OUTER_COLOR
        barPart.Transparency = ROUTE_OUTER_TRANSP
        barPart.Parent       = workspace
        table.insert(routeParts, barPart)

        -- Place tiny & medium cubes along the bar
        local halfBar = barLength / 2
        for d = ROUTE_TINY_INTERVAL, barLength - ROUTE_TINY_INTERVAL, ROUTE_TINY_INTERVAL do
            local cf = barPart.CFrame * CFrame.new(0, 0, -halfBar + d)
            -- Tiny cube
            spawnRouteCube(
                cf,
                Vector3.new(ROUTE_LINE_THICKNESS, ROUTE_LINE_THICKESS, ROUTE_LINE_THICKNESS),
                Vector3.new(ROUTE_LINE_THICKNESS - 0.1, ROUTE_LINE_THICKNESS - 0.1, ROUTE_LINE_THICKNESS - 0.1),
                ROUTE_OUTER_COLOR, ROUTE_OUTER_TRANSP,
                ROUTE_INNER_COLOR, ROUTE_INNER_TRANSP
            )
            -- Medium cube at multiples of MEDIUM_INTERVAL
            if d % ROUTE_MEDIUM_INTERVAL == 0 then
                spawnRouteCube(
                    cf,
                    ROUTE_MED_OUTER_SIZE, ROUTE_MED_INNER_SIZE,
                    ROUTE_MED_OUTER_COLOR, ROUTE_MED_OUTER_TRANSP,
                    ROUTE_MED_INNER_COLOR, ROUTE_MED_INNER_TRANSP,
                    Enum.Material.SmoothPlastic
                )
            end
        end
    end

    -- 3) End cap
    local endCF = CFrame.new(ROUTE_END_POS, ROUTE_END_POS + forward)
    spawnRouteCube(
        endCF,
        ROUTE_OUTER_SIZE, ROUTE_INNER_SIZE,
        ROUTE_OUTER_COLOR, ROUTE_OUTER_TRANSP,
        ROUTE_INNER_COLOR, ROUTE_INNER_TRANSP
    )

    routingActive = true
end

-- Remove/destroy all route parts
local function removeRouteA()
    for _, part in ipairs(routeParts) do
        if part and part.Parent then
            part:Destroy()
        end
    end
    routeParts      = {}
    routingActive   = false
    routeRunning    = false
    routePaused     = false
    if routeConn then
        routeConn:Disconnect()
        routeConn = nil
    end
    routeGuidesData = {}
    routeStartTime  = 0
    pausedElapsed   = 0
    routeDuration   = 0
end

-- ────────────────────────────────────────────────────────────
-- FUNCTION: Teleport all existing plates to Route Start (centering by their grid center)
-- ────────────────────────────────────────────────────────────
local function resetRouteA()
    if not routingActive then return end
    -- For each guide, find centroid of its Core parts, compute offset,
    -- then set PrimaryPart to startBase * offset
    local startBase = ROUTE_START_POS + Vector3.new(0, heightOffset, 0)

    for _, guideModel in pairs(plates) do
        if guideModel.PrimaryPart then
            -- 1) collect all “Core_” parts
            local cores = {}
            for _, p in ipairs(guideModel:GetDescendants()) do
                if p:IsA("BasePart") and p.Name:match("^Core_R%d+_C%d+") then
                    table.insert(cores, p)
                end
            end

            if #cores == 0 then
                -- fallback if no Core parts found
                local pivotCFrame = guideModel.PrimaryPart.CFrame
                local offset = pivotCFrame:ToObjectSpace(guideModel.PrimaryPart.CFrame)
                guideModel:SetPrimaryPartCFrame(CFrame.new(startBase) * offset)
            else
                -- 2) average their world‑space positions
                local sum = Vector3.new(0, 0, 0)
                for _, core in ipairs(cores) do
                    sum = sum + core.Position
                end
                local center = sum / #cores  -- centroid of grid

                -- 3) pivotCFrame at that center
                local pivotCFrame = CFrame.new(center)

                -- 4) compute offset = pivotCFrame:ToObjectSpace(PrimaryPart.CFrame)
                local offset = pivotCFrame:ToObjectSpace(guideModel.PrimaryPart.CFrame)

                -- 5) place entire model so centroid → startBase
                guideModel:SetPrimaryPartCFrame(CFrame.new(startBase) * offset)
            end
        end
    end
end

-- ────────────────────────────────────────────────────────────
-- START/CONTINUE THE ROUTE A ANIMATION
-- ────────────────────────────────────────────────────────────
local function startRouteAnimation()
    if not routingActive then return end
    if routeRunning and not routePaused then return end

    -- If first time or after reset, build routeGuidesData & compute duration
    if not routeRunning then
        routeGuidesData = {}  -- reset

        -- Prepare a list of {model, offset} for each plate
        local totalDistance = (ROUTE_END_POS - ROUTE_START_POS).Magnitude
        if totalDistance == 0 then return end
        routeDuration = totalDistance / ROUTE_SPEED

        local startBase = ROUTE_START_POS + Vector3.new(0, heightOffset, 0)

        for _, guideModel in pairs(plates) do
            if guideModel.PrimaryPart then
                -- collect "Core_" parts
                local cores = {}
                for _, p in ipairs(guideModel:GetDescendants()) do
                    if p:IsA("BasePart") and p.Name:match("^Core_R%d+_C%d+") then
                        table.insert(cores, p)
                    end
                end
                if #cores == 0 then
                    -- fallback
                    local pivotCFrame = guideModel.PrimaryPart.CFrame
                    local offset = pivotCFrame:ToObjectSpace(guideModel.PrimaryPart.CFrame)
                    guideModel:SetPrimaryPartCFrame(CFrame.new(startBase) * offset)
                    table.insert(routeGuidesData, { model = guideModel, offset = offset })
                else
                    local sum = Vector3.new(0,0,0)
                    for _, core in ipairs(cores) do
                        sum = sum + core.Position
                    end
                    local center = sum / #cores
                    local pivotCFrame = CFrame.new(center)
                    local offset = pivotCFrame:ToObjectSpace(guideModel.PrimaryPart.CFrame)
                    guideModel:SetPrimaryPartCFrame(CFrame.new(startBase) * offset)
                    table.insert(routeGuidesData, { model = guideModel, offset = offset })
                end
            end
        end

        -- Initialize timing
        routeStartTime  = tick()
        pausedElapsed   = 0
        routeRunning    = true
        routePaused     = false
    else
        -- We are resuming from a pause
        -- Adjust startTime so that elapsed = pausedElapsed
        routeStartTime = tick() - pausedElapsed
        routePaused    = false
    end

    -- Disconnect any existing connection
    if routeConn then
        routeConn:Disconnect()
        routeConn = nil
    end

    -- Start Heartbeat loop
    routeConn = RunService.Heartbeat:Connect(function()
        local elapsed = tick() - routeStartTime
        if elapsed < 0 then elapsed = 0 end
        local alpha = elapsed / routeDuration
        if alpha >= 1 then
            alpha = 1
        end

        -- current position along route
        local currentPos = (ROUTE_START_POS + Vector3.new(0, heightOffset, 0)):Lerp(
                             (ROUTE_END_POS + Vector3.new(0, heightOffset, 0)),
                             alpha
                           )

        -- Move each guide
        for _, data in ipairs(routeGuidesData) do
            local gm  = data.model
            local off = data.offset
            gm:SetPrimaryPartCFrame(CFrame.new(currentPos) * off)
        end

        if alpha >= 1 then
            -- Reached end; disconnect
            routeConn:Disconnect()
            routeConn = nil
            routeRunning = false
            routePaused = false
            -- (Optionally, you might update the Pause button text here back to "Pause")
        end
    end)
end

-- ────────────────────────────────────────────────────────────
-- PAUSE or RESUME THE ROUTE A ANIMATION
-- ────────────────────────────────────────────────────────────
local function togglePauseRouteA(pauseBtnLabel)
    if not routingActive or not routeRunning then
        return
    end

    if not routePaused then
        -- Pause it
        routePaused = true
        if routeConn then
            routeConn:Disconnect()
            routeConn = nil
        end
        -- Compute pausedElapsed = elapsed so far
        pausedElapsed = tick() - routeStartTime
        pauseBtnLabel.Text = "Resume Route"
        pauseBtnLabel.Parent.BackgroundColor3 = Color3.fromRGB(50, 200, 50)  -- green when paused
    else
        -- Resume it
        pauseBtnLabel.Text = "Pause Route"
        pauseBtnLabel.Parent.BackgroundColor3 = Color3.fromRGB(55, 55, 70)
        startRouteAnimation()
    end
end

